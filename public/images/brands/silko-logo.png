<script type="text/javascript">

function resetFiltri(){
    $('#realizzazioni-1').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-2').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-3').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-4').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-5').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-6').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});
    $('#realizzazioni-7').find('.elementor-button-text').css({"color":"#002940","font-weight":"400"});

    $('.realizzazioni-1-images').hide();
    $('.realizzazioni-2-images').hide();
    $('.realizzazioni-3-images').hide();
    $('.realizzazioni-4-images').hide();
    $('.realizzazioni-5-images').hide();

}
$(document).ready(function(){

    $('.realizzazioni-1-images').show();
    $('.realizzazioni-2-images').hide();
    $('.realizzazioni-3-images').hide();
    $('.realizzazioni-4-images').hide();
    $('.realizzazioni-5-images').hide();

    //$('#realizzazioni-1').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
    //$('.realizzazioni-1-images').show();
    
	;
	
	var POST = [];
        
    if(POST != null){      
        switch(POST["category"]){
          case "fine-dining":
            resetFiltri(); 
            $('#realizzazioni-2').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('.realizzazioni-2-images').show();
            break;
          case "hotel":
            resetFiltri(); 
            $('#realizzazioni-3').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('.realizzazioni-3-images').show(); 
            break;
          case "colletivita":
            resetFiltri();       
            $('#realizzazioni-4').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('#realizzazioni-6').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('.realizzazioni-4-images').show(); 
            break;
          case "ristoranti":
            resetFiltri(); 
            $('#realizzazioni-5').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('#realizzazioni-7').find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
            $('.realizzazioni-5-images').show(); 
            break;  
        }
    }

    
    $('.realizzazioni-title-button').on('click', function()
    {
        resetFiltri(); 
        
        var id = $(this).attr("id");
        
        //SET CSS REALIZZAZIONI TITLE SELECTED BUTTON
        $(this).find('.elementor-button-text').css({"color":"#D7761E","font-weight":"700"});
        
        //SHOW SELECTED REALIZZAZIONE IMAGES
        if(id == "realizzazioni-6"){
            $('.realizzazioni-4-images').show(); 
        }
        else{
            if(id == "realizzazioni-7"){
                $('.realizzazioni-5-images').show(); 
            }
            else{
                $('.' + id + '-images').show(); 
            }
        }
           
    });
});
</script>	<script>
