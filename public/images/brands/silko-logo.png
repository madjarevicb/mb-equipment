			<style class="wpcode-css-snippet">.catalogo-interattivo a{
	border-bottom: 1px solid #002940;
}

.catalogo-interattivo:hover, .catalogo-interattivo a:hover, .catalogo-interattivo:focus, .catalogo-interattivo a:focus{
	color: #002940!important;
}</style><script>document.addEventListener('DOMContentLoaded', () => {
  const btnFdlSupports = document.querySelectorAll('.btn-fdl-support');

  btnFdlSupports.forEach(btnFdlSupport => {
    const btnFdlBackground = btnFdlSupport.querySelector('div');
    const btnFdlTitle = btnFdlSupport.querySelector('.btn-fdl-title');
    const btnFdlTitleColor = btnFdlSupport.querySelector('.btn-fdl-title div div');
    const img = btnFdlSupport.querySelector('img');
    const btnFdlParagraph = btnFdlSupport.querySelector('.btn-fdl-paragraph');
    const btnFdlParagraphColor = btnFdlSupport.querySelector('.btn-fdl-paragraph div div');

    function centerVertically() {
      const containerHeight = btnFdlSupport.offsetHeight;
      const titleHeight = btnFdlTitle.offsetHeight;
      const paragraphHeight = btnFdlParagraph ? btnFdlParagraph.offsetHeight : 0;

      const totalHeight = titleHeight + paragraphHeight;
      const topOffset = (containerHeight - totalHeight) / 2;

      btnFdlTitle.style.top = `${topOffset}px`;
      if (btnFdlParagraph) {
        btnFdlParagraph.style.top = `${topOffset + titleHeight}px`;
        btnFdlParagraph.style.visibility = 'visible';
      }
    }

    btnFdlSupport.addEventListener('mouseover', () => {
      img.style.display = 'none';
      btnFdlBackground.style.backgroundColor = '#CE7E19';
      btnFdlTitleColor.style.color = '#fff';
      btnFdlParagraphColor.style.color = '#fff';

      centerVertically();

      if (btnFdlParagraph) {
        btnFdlParagraph.classList.add('visible');
      }
    });

    btnFdlSupport.addEventListener('mouseout', () => {
      img.style.display = 'initial';
      btnFdlTitle.style.top = '';
      btnFdlTitle.style.transform = '';

      btnFdlBackground.style.backgroundColor = ''; // Ripristina il colore di sfondo originale
      btnFdlTitleColor.style.color = '#002940'; // Ripristina il colore del testo originale
      if (btnFdlParagraph) {
        btnFdlParagraph.classList.remove('visible');
        btnFdlParagraph.style.top = '';
        btnFdlParagraph.style.transform = '';
        btnFdlParagraph.style.visibility = 'hidden';
      }
    });
  });
});
</script><style class='wp-fonts-local'>
